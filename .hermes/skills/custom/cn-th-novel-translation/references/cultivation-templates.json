      "count": 12,
      "notes": "ใช้ตอนแสดงความโกรธ/ดูถูก"
    },
    "his expression changed slightly": {
      "th": "สีหน้าแปรเปลี่ยนเล็กน้อย",
      "first_seen": "ch003",
      "count": 8
    },
    "in the blink of an eye": {
      "th": "ชั่วพริบตา",
